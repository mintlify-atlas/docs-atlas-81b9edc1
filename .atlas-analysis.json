  "keyFeatures": [
    "Dual-language SDK for Python and TypeScript/JavaScript with WASM and Cython bindings",
    "Create, sign, and broadcast Hive blockchain transactions",
    "Offline transaction building with createWaxFoundation/create_wax_foundation",
    "Online blockchain operations with createHiveChain/create_hive_chain",
    "Pluggable signing providers (Beekeeper, Keychain, MetaMask, PeakVault)",
    "Extendable API and REST API interfaces",
    "Protocol buffer-based operations from hived C++ source",
    "Multi-framework support (Next.js, React, Vue, Nuxt, Node.js)",
    "Custom formatters for transaction output",
    "Complex operations for account updates, voting, transfers, and proposals"
  ],
  "publicApiSurface": [
    "createWaxFoundation() / create_wax_foundation()",
    "createHiveChain() / create_hive_chain()",
    "IWaxBaseInterface.createTransaction()",
    "IWaxBaseInterface.pushOperation()",
    "IWaxBaseInterface.calculateManabarFullRegenerationTime()",
    "IHiveChainInterface.api.*",
    "IHiveChainInterface.broadcast()",
    "ITransaction.sign()",
    "ITransaction.validate()",
    "hiveCoins() / vests() / hbd()",
    "encodeToProto() / decodeFromProto()",
    "getTransactionId()",
    "calculateManabarRegenerationTime()",
    "complexOperations.updateAccount()",
    "complexOperations.comment()",
    "complexOperations.vote()",
    "complexOperations.recurrentTransfer()"
  ]
